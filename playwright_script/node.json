{
  "node_type": "playwright_script",
  "name": "Playwright",
  "description": "执行可参数化的 Python Playwright 脚本",
  "category": "浏览器自动化",
  "version": "1.0.0",
  "entry_file": "node.py",
  "dependencies": ["playwright"],
  "metadata": {"node_kind": "playwright_script"},
  "examples": [
    {
      "title": "打开网页截图",
      "description": "访问指定URL并截取页面图片保存到本地",
      "config": {"url": "https://example.com", "save_path": "screenshot.png"}
    },
    {
      "title": "自动登录",
      "description": "自动填写用户名密码并点击登录按钮",
      "config": {"url": "https://app.example.com/login", "username": "admin", "password": "******"}
    }
  ]
}
