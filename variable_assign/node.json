{
  "node_type": "variable_assign",
  "name": "变量赋值",
  "description": "创建变量并赋值",
  "category": "变量操作",
  "version": "1.0.0",
  "entry_file": "node.py",
  "dependencies": [],
  "config_schema": {
    "variable_name": {"type": "string", "label": "变量名"},
    "value": {"type": "string", "label": "值"},
    "value_type": {"type": "enum", "options": ["str", "int", "float", "bool", "json"], "label": "类型"}
  },
  "examples": [
    {
      "title": "赋值字符串",
      "description": "将字符串常量赋给变量 greeting",
      "config": {"variable_name": "greeting", "value": "你好世界", "value_type": "str"}
    },
    {
      "title": "赋值数字",
      "description": "将整数值赋给变量 count",
      "config": {"variable_name": "count", "value": "100", "value_type": "int"}
    },
    {
      "title": "赋值JSON对象",
      "description": "将JSON对象赋给变量 config",
      "config": {"variable_name": "config", "value": "{\"host\": \"localhost\", \"port\": 8080}", "value_type": "json"}
    }
  ]
}
