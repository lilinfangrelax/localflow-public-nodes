{
  "node_type": "table_aggregate",
  "name": "表格聚合",
  "description": "对表格 rows 数据执行筛选、分组和指标统计",
  "category": "表格处理",
  "version": "1.0.0",
  "entry_file": "node.py",
  "dependencies": [],
  "config_schema": {
    "input_rows_var": {"type": "string", "label": "输入变量", "default": "table_data"},
    "filters": {"type": "json", "label": "过滤条件", "default": []},
    "group_by": {"type": "json", "label": "分组字段", "default": []},
    "metrics": {"type": "json", "label": "统计指标", "default": []},
    "sort_by": {"type": "json", "label": "排序规则", "default": []},
    "limit": {"type": "int", "label": "结果条数限制", "default": 0},
    "output_var": {"type": "string", "label": "输出变量", "default": "aggregate_result"}
  },
  "examples": [
    {
      "title": "按部门分组统计",
      "description": "按部门分组，计算每组的平均薪资和人数",
      "config": {"input_rows_var": "table_data", "group_by": ["dept"], "metrics": [{"field": "salary", "func": "avg"}, {"field": "salary", "func": "count"}], "output_var": "aggregate_result"}
    },
    {
      "title": "过滤后排序",
      "description": "筛选年龄大于25的记录，按薪资降序排列取前10",
      "config": {"input_rows_var": "table_data", "filters": [{"field": "age", "op": ">", "value": 25}], "sort_by": [{"field": "salary", "order": "desc"}], "limit": 10, "output_var": "aggregate_result"}
    }
  ]
}
