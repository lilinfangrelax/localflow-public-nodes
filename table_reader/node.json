{
  "node_type": "table_reader",
  "name": "表格读取",
  "description": "读取 Excel 或 CSV 文件并输出结构化表格数据",
  "category": "表格处理",
  "version": "1.0.0",
  "entry_file": "node.py",
  "dependencies": ["openpyxl", "pandas", "xlrd"],
  "config_schema": {
    "file_path": {"type": "string", "label": "文件路径"},
    "file_type": {"type": "enum", "label": "文件类型", "options": ["auto", "excel", "csv"], "default": "auto"},
    "sheet_name": {"type": "string", "label": "Sheet 名称", "default": ""},
    "header_row": {"type": "int", "label": "表头行", "default": 0},
    "encoding": {"type": "string", "label": "CSV 编码", "default": "utf-8-sig"},
    "skip_empty_rows": {"type": "bool", "label": "跳过空行", "default": true},
    "output_var": {"type": "string", "label": "输出变量", "default": "table_data"}
  },
  "examples": [
    {
      "title": "读取Excel文件",
      "description": "自动识别格式，读取销售数据 Excel",
      "config": {"file_path": "data/sales.xlsx", "file_type": "auto", "output_var": "table_data"}
    },
    {
      "title": "读取指定Sheet",
      "description": "读取 Excel 中名为「1月」的 Sheet",
      "config": {"file_path": "data/report.xlsx", "file_type": "excel", "sheet_name": "1月", "output_var": "table_data"}
    },
    {
      "title": "读取CSV文件",
      "description": "读取 GBK 编码的 CSV 文件",
      "config": {"file_path": "data/contacts.csv", "file_type": "csv", "encoding": "gbk", "output_var": "table_data"}
    }
  ]
}
