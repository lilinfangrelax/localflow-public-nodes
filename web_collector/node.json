{
  "node_type": "web_collector",
  "name": "Web 收集器",
  "description": "通过 WebSocket 接收浏览器插件收集的页面数据（页面信息、网络请求、控制台日志、DOM事件等）",
  "category": "数据收集",
  "version": "1.0.0",
  "entry_file": "node.py",
  "dependencies": ["websockets"],
  "config_schema": {
    "ws_port": {"type": "int", "label": "WebSocket 端口", "default": 8765},
    "timeout_seconds": {"type": "int", "label": "等待超时(秒)", "default": 60},
    "collect_types": {"type": "string", "label": "收集类型(逗号分隔)", "default": "page_info,network,console"},
    "max_messages": {"type": "int", "label": "最大收集消息数", "default": 100},
    "output_var": {"type": "string", "label": "输出变量名", "default": "collected_data"}
  },
  "examples": [
    {
      "title": "收集网络请求",
      "description": "仅收集浏览器网络请求数据",
      "config": {"ws_port": 8765, "collect_types": "network", "timeout_seconds": 30, "output_var": "collected_data"}
    },
    {
      "title": "全量收集",
      "description": "收集页面信息、网络请求和控制台日志",
      "config": {"ws_port": 8765, "collect_types": "page_info,network,console", "max_messages": 200, "output_var": "collected_data"}
    }
  ]
}
